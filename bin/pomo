#!/usr/bin/env zsh
# pomo - Pomodoro timer with desktop notifications
#
# Usage:
#   pomo work [minutes] [message...]
#   pomo rest [minutes] [message...]
#
# Examples:
#   pomo work                    # 25 minute work timer
#   pomo rest                    # 5 minute rest timer
#   pomo work 45                 # 45 minute work timer
#   pomo rest 15 some message    # 15 minute rest with "some message"
#   pomo rest some message 15    # number can be anywhere among args

source "${0:A:h}/p-common.zsh"

typeset -gr POMO_DEFAULT_WORK=25
typeset -gr POMO_DEFAULT_REST=5
typeset -gr POMO_WORK_EMOJI="🎯"
typeset -gr POMO_REST_EMOJI="☕"
typeset -gr POMO_WORK_SLACK_EMOJI=":dart:"
typeset -gr POMO_REST_SLACK_EMOJI=":coffee:"
typeset -gr POMO_KEYCHAIN_ACCOUNT="productive"
typeset -gr POMO_KEYCHAIN_SERVICE="SLACK_TOKEN"
typeset -gr POMO_FOCUS_SHORTCUT_ON="Pomo DND On"
typeset -gr POMO_FOCUS_SHORTCUT_OFF="Pomo DND Off"
typeset -gr POMO_FOCUS_RESTORE_WORK_SHORTCUT="Pomo Focus Work"
typeset -gr POMO_FOCUS_RESTORE_SLEEP_SHORTCUT="Pomo Focus Sleep"
typeset -gr POMO_FOCUS_DB_ASSERTIONS="$HOME/Library/DoNotDisturb/DB/Assertions.json"
typeset -gr POMO_FOCUS_MODE_WORK="com.apple.focus.work"
typeset -gr POMO_FOCUS_MODE_SLEEP="com.apple.sleep.sleep-mode"

show_help() {
  cat <<EOF
pomo - Pomodoro timer with desktop notifications and Slack status

Usage:
  pomo [--no-slack] work [minutes] [message...]
  pomo [--no-slack] rest [minutes] [message...]

Arguments:
  minutes   Optional duration in minutes
            (defaults: ${POMO_DEFAULT_WORK} for work, ${POMO_DEFAULT_REST} for rest)
  message   Optional message to display

Flags:
  --no-slack   Skip Slack status update and DND snooze for this run.
               Slack is also auto-skipped if no SLACK_TOKEN is in macOS Keychain
               (account: ${POMO_KEYCHAIN_ACCOUNT}, service: ${POMO_KEYCHAIN_SERVICE}).
  --no-focus   Skip macOS Focus toggle for this run.
               Focus is also auto-skipped if 'shortcuts' CLI is not available
               or the '${POMO_FOCUS_SHORTCUT_ON}' / '${POMO_FOCUS_SHORTCUT_OFF}' shortcuts are missing.

Notes:
  Any positive integer in args is treated as the duration; the rest is the message.
  Trailing position is checked first, then leading position.
  Slack status auto-expires when the timer ends; DND snoozes only during 'work'.
  macOS Focus is enabled only during 'work' and turned off when the timer ends.

Examples:
  pomo work
  pomo rest
  pomo work 45
  pomo rest 15 quick coffee
  pomo rest quick coffee 15
  pomo --no-slack work 25 offline focus
EOF
}

# Parse mode/duration/message from args
# Sets globals: POMO_MODE, POMO_DURATION, POMO_MESSAGE
# Usage: parse_args <mode> [args...]
parse_args() {
  local mode=$1
  shift
  local args=("$@")

  if [[ ! "$mode" =~ ^(work|rest)$ ]]; then
    die "First argument must be either 'work' or 'rest'"
  fi

  local default_duration
  default_duration=$([[ "$mode" == "work" ]] && echo $POMO_DEFAULT_WORK || echo $POMO_DEFAULT_REST)

  local duration=""
  local message=""

  if (( ${#args[@]} == 0 )); then
    duration=$default_duration
  elif [[ "${args[-1]}" =~ ^[0-9]+$ ]]; then
    duration="${args[-1]}"
    message="${(j: :)args[1,-2]}"
  elif [[ "${args[1]}" =~ ^[0-9]+$ ]]; then
    duration="${args[1]}"
    message="${(j: :)args[2,-1]}"
  else
    duration=$default_duration
    message="${(j: :)args}"
  fi

  if [[ -z "${message// }" ]]; then
    message=$([[ "$mode" == "work" ]] && echo "Work timer" || echo "Rest timer")
  fi

  POMO_MODE="$mode"
  POMO_DURATION="$duration"
  POMO_MESSAGE="$message"
}

# Print start banner
# Usage: print_banner <mode> <duration> <message>
print_banner() {
  local mode=$1
  local duration=$2
  local message=$3
  local emoji=$([[ "$mode" == "work" ]] && echo "$POMO_WORK_EMOJI" || echo "$POMO_REST_EMOJI")

  clear
  echo ""
  echo "$emoji $message started for $duration minutes"
  echo ""
}

# Escape a string for safe inclusion as a JSON string value
# Usage: json_escape <string>
# Note: handles \, ", \n, \t, \r. Does not handle other control chars.
# Uses local vars instead of inline backslash escapes because zsh's parameter
# replacement strips backslashes from inline literals like "\\\"".
json_escape() {
  local s=$1
  local bs='\' dq='"'
  s=${s//$bs/${bs}${bs}}
  s=${s//$dq/${bs}${dq}}
  s=${s//$'\n'/${bs}n}
  s=${s//$'\t'/${bs}t}
  s=${s//$'\r'/${bs}r}
  print -r -n -- "$s"
}

# Get Slack user OAuth token from macOS Keychain
# Usage: slack_token
# Returns: token on stdout, empty string if not found
slack_token() {
  security find-generic-password \
    -a "$POMO_KEYCHAIN_ACCOUNT" \
    -s "$POMO_KEYCHAIN_SERVICE" \
    -w 2>/dev/null
}

# Set Slack user status (text + emoji + auto-expiration)
# Usage: slack_set_status <emoji> <text> <expiration_unix_ts>
# No-ops silently if no token is available.
slack_set_status() {
  local emoji=$1 text=$2 expiration=$3
  local token
  token=$(slack_token)
  [[ -z "$token" ]] && return 0

  local payload
  payload=$(printf '{"profile":{"status_text":"%s","status_emoji":"%s","status_expiration":%d}}' \
    "$(json_escape "$text")" "$(json_escape "$emoji")" "$expiration")

  curl -sS --max-time 5 -X POST \
    -H "Authorization: Bearer $token" \
    -H "Content-Type: application/json; charset=utf-8" \
    -d "$payload" \
    "https://slack.com/api/users.profile.set" >/dev/null
}

# Clear Slack user status
# Usage: slack_clear_status
slack_clear_status() {
  slack_set_status "" "" 0
}

# Snooze Slack DND for N minutes
# Usage: slack_dnd_snooze <minutes>
slack_dnd_snooze() {
  local minutes=$1
  local token
  token=$(slack_token)
  [[ -z "$token" ]] && return 0

  curl -sS --max-time 5 -X POST \
    -H "Authorization: Bearer $token" \
    --data-urlencode "num_minutes=$minutes" \
    "https://slack.com/api/dnd.setSnooze" >/dev/null
}

# End Slack DND snooze
# Usage: slack_dnd_end
slack_dnd_end() {
  local token
  token=$(slack_token)
  [[ -z "$token" ]] && return 0

  curl -sS --max-time 5 -X POST \
    -H "Authorization: Bearer $token" \
    "https://slack.com/api/dnd.endSnooze" >/dev/null
}

# Read the currently active macOS Focus mode identifier
# Usage: focus_current_mode
# Returns: mode identifier on stdout (e.g. "com.apple.focus.work"), empty if no Focus active
# Reads ~/Library/DoNotDisturb/DB/Assertions.json - this is the live state file used by donotdisturbd.
# storeAssertionRecords[] is the array of currently-active assertions; empty array == no Focus.
focus_current_mode() {
  [[ -r "$POMO_FOCUS_DB_ASSERTIONS" ]] || return 0
  jq -r '
    .data[0].storeAssertionRecords[0].assertionDetails.assertionDetailsModeIdentifier // empty
  ' "$POMO_FOCUS_DB_ASSERTIONS" 2>/dev/null
}

# Map a Focus mode identifier to a restore shortcut name
# Usage: focus_restore_shortcut <mode_identifier>
# Returns: shortcut name on stdout, empty if no restore shortcut is defined for that mode
# Add new mappings here as you create more "Pomo Focus <name>" shortcuts.
focus_restore_shortcut() {
  case $1 in
    "$POMO_FOCUS_MODE_WORK")  print -r -- "$POMO_FOCUS_RESTORE_WORK_SHORTCUT" ;;
    "$POMO_FOCUS_MODE_SLEEP") print -r -- "$POMO_FOCUS_RESTORE_SLEEP_SHORTCUT" ;;
    *) ;;
  esac
}

# Turn macOS Focus (Do Not Disturb) on via Shortcuts CLI
# Usage: focus_session_start
focus_session_start() {
  shortcuts run "$POMO_FOCUS_SHORTCUT_ON" </dev/null >/dev/null 2>&1
}

# Turn macOS Focus off and restore previously-active mode if we have a shortcut for it
# Usage: focus_session_end <previous_mode_identifier>
# Pass empty string if no mode was active before the session.
focus_session_end() {
  local prev_mode=$1
  shortcuts run "$POMO_FOCUS_SHORTCUT_OFF" </dev/null >/dev/null 2>&1

  [[ -z "$prev_mode" ]] && return 0
  local restore_shortcut
  restore_shortcut=$(focus_restore_shortcut "$prev_mode")
  [[ -z "$restore_shortcut" ]] && return 0
  shortcuts list 2>/dev/null | grep -qxF "$restore_shortcut" || return 0
  shortcuts run "$restore_shortcut" </dev/null >/dev/null 2>&1
}

# Send completion notification
# Usage: notify_complete <mode> <message>
notify_complete() {
  local mode=$1
  local message=$2
  local emoji title
  if [[ "$mode" == "work" ]]; then
    emoji="$POMO_WORK_EMOJI"
    title="Work timer is up! Take a break ☕"
  else
    emoji="$POMO_REST_EMOJI"
    title="Rest timer is up! Get back to work 🎯"
  fi

  terminal-notifier \
    -message "$emoji $message" \
    -title "$title" \
    -sound default >/dev/null
}

# Strip --no-slack from positional args
# Sets global POMO_NO_SLACK=1 if flag was present, then sets POMO_FILTERED_ARGS
# Usage: filter_flags "$@"
filter_flags() {
  POMO_NO_SLACK=0
  POMO_NO_FOCUS=0
  POMO_FILTERED_ARGS=()
  local a
  for a in "$@"; do
    case "$a" in
      --no-slack) POMO_NO_SLACK=1 ;;
      --no-focus) POMO_NO_FOCUS=1 ;;
      *)          POMO_FILTERED_ARGS+=("$a") ;;
    esac
  done
}

# Decide whether Slack updates should happen this run
# Usage: slack_enabled
# Returns: 0 if enabled, 1 if disabled
slack_enabled() {
  (( POMO_NO_SLACK )) && return 1
  [[ -n "$(slack_token)" ]]
}

# Decide whether macOS Focus toggle should happen this run
# Usage: focus_enabled <mode>
# Returns: 0 if enabled, 1 if disabled
# Focus only triggers for 'work' mode (rest stays interruptible).
focus_enabled() {
  local mode=$1
  (( POMO_NO_FOCUS )) && return 1
  [[ "$mode" == "work" ]] || return 1
  command -v shortcuts &>/dev/null || return 1
  shortcuts list 2>/dev/null | grep -qxF "$POMO_FOCUS_SHORTCUT_ON" || return 1
  shortcuts list 2>/dev/null | grep -qxF "$POMO_FOCUS_SHORTCUT_OFF" || return 1
}

# Apply Slack status + (for work) DND snooze for this session
# Usage: slack_session_start <mode> <duration> <message>
slack_session_start() {
  local mode=$1 duration=$2 message=$3
  local emoji expire_ts
  expire_ts=$(( $(date +%s) + duration * 60 ))

  if [[ "$mode" == "work" ]]; then
    emoji="$POMO_WORK_SLACK_EMOJI"
    slack_set_status "$emoji" "$message" "$expire_ts"
    slack_dnd_snooze "$duration"
  else
    emoji="$POMO_REST_SLACK_EMOJI"
    slack_set_status "$emoji" "$message" "$expire_ts"
  fi
}

# Restore Slack to neutral state (clear status, end DND if work)
# Usage: slack_session_end <mode>
slack_session_end() {
  local mode=$1
  slack_clear_status
  [[ "$mode" == "work" ]] && slack_dnd_end
  return 0
}

main() {
  if [[ "$1" == "--help" || "$1" == "-h" ]]; then
    show_help
    return 0
  fi

  check_command timer
  check_command terminal-notifier

  filter_flags "$@"
  parse_args "${POMO_FILTERED_ARGS[@]}" || exit $?

  local slack_on=0 focus_on=0
  local focus_prev_mode=""
  if slack_enabled; then
    slack_on=1
    slack_session_start "$POMO_MODE" "$POMO_DURATION" "$POMO_MESSAGE"
  fi
  if focus_enabled "$POMO_MODE"; then
    focus_on=1
    focus_prev_mode=$(focus_current_mode)
    focus_session_start
  fi
  if (( slack_on || focus_on )); then
    trap '(( slack_on )) && slack_session_end "$POMO_MODE"; (( focus_on )) && focus_session_end "$focus_prev_mode"; exit 130' INT TERM
  fi

  print_banner "$POMO_MODE" "$POMO_DURATION" "$POMO_MESSAGE"

  if ! timer "${POMO_DURATION}m"; then
    local rc=$?
    (( slack_on )) && slack_session_end "$POMO_MODE"
    (( focus_on )) && focus_session_end "$focus_prev_mode"
    exit $rc
  fi

  trap - INT TERM
  (( slack_on )) && slack_session_end "$POMO_MODE"
  (( focus_on )) && focus_session_end "$focus_prev_mode"

  notify_complete "$POMO_MODE" "$POMO_MESSAGE"
}

# Skip main when sourced (e.g. in tests)
[[ $ZSH_EVAL_CONTEXT =~ :file$ ]] && return || main "$@"
