#!/usr/bin/env zsh
# prun-work - Refresh productive/work repo + all repos/* reference checkouts
# Usage: prun-work
#
# For each of: the work repo itself, and every git repo under repos/*:
#   - If pristine (no modified tracked files, no unpushed commits on a non-default
#     branch) → switch to default branch (develop > main > master), fetch, pull --ff-only
#   - Otherwise → flag in the "needs attention" section, don't touch
#
# Untracked files are NOT considered dirty (some repos have autogenerated junk
# like .pnpm-store/ that isn't in .gitignore).
#
# Output is streamed per-repo (each line appears as soon as that repo finishes),
# with a count summary at the end. Colored markers (✓ ⚠ ✗ ·) let you scan for
# anything that needs attention.

set -u

source "${0:A:h}/p-common.zsh"

typeset -r EXPECTED_REPO="productiveio/work"

show_help() {
  cat << EOF
prun-work - Refresh work repo + repos/* reference checkouts

USAGE:
  prun-work [--help]

WHAT IT DOES:
  For the work repo and every git repo under repos/*:
    - Pristine repos are switched to their default branch (develop > main >
      master fallback) and fast-forwarded.
    - Repos with modified tracked files or unpushed commits on a non-default
      branch are flagged — never modified.

  Untracked files (e.g. .pnpm-store/, build artifacts) are ignored.

REQUIREMENTS:
  - Must be run from inside productive/work
  - Requires git, pdetect, jq
EOF
  exit 0
}

# Resolve the default branch for a repo: prefer develop, then main, then master.
# Echoes branch name on success, returns non-zero if none of those exist on origin.
default_branch() {
  local dir=$1
  local b
  for b in develop main master; do
    if git -C "$dir" show-ref --verify --quiet "refs/remotes/origin/$b"; then
      echo "$b"
      return 0
    fi
  done
  return 1
}

# Decide whether a repo can be safely synced.
# Sets global PRISTINE_REASON when returning 1.
can_sync() {
  local dir=$1
  PRISTINE_REASON=""

  # Modified or staged tracked files → never touch (untracked files are OK)
  if [[ -n "$(git -C "$dir" status --porcelain --untracked-files=no 2>/dev/null)" ]]; then
    PRISTINE_REASON="dirty working tree"
    return 1
  fi

  local current default
  current=$(git -C "$dir" rev-parse --abbrev-ref HEAD 2>/dev/null)
  if ! default=$(default_branch "$dir"); then
    PRISTINE_REASON="no develop/main/master on origin"
    return 1
  fi

  # On a non-default branch — only safe to switch away if no unpushed work
  if [[ "$current" != "$default" ]]; then
    local ahead
    if ! ahead=$(git -C "$dir" rev-list --count '@{u}..HEAD' 2>/dev/null); then
      PRISTINE_REASON="on '$current' (no upstream tracking)"
      return 1
    fi
    if [[ "$ahead" -gt 0 ]]; then
      PRISTINE_REASON="on '$current' with $ahead unpushed commit(s)"
      return 1
    fi
  fi

  return 0
}

# Compact a multi-line git error message into a single short line.
# Echoes the first meaningful (non-empty, non-hint) line.
first_error_line() {
  echo "$1" | grep -vE '^[[:space:]]*$|^hint:|^Please' | head -1 | sed 's/^[[:space:]]*//'
}

# If <repo>/.git/index.lock exists, is 0 bytes (never written-to), and no
# process holds it open, it's a stale lock — safely remove it. Returns 0 if
# safe-to-continue (no lock OR lock was stale and removed), 1 if a live lock
# is being held by something. Echoes a brief note when it removes a stale lock.
clear_stale_index_lock() {
  local dir=$1
  local lock="$dir/.git/index.lock"
  [[ -e "$lock" ]] || return 0
  # Held by anyone? lsof prints to stdout if yes; we send stderr to /dev/null
  # to ignore "lsof: WARNING: ..." noise on macOS.
  if lsof -- "$lock" >/dev/null 2>&1; then
    return 1  # live lock — someone is using it, do not touch
  fi
  local size
  size=$(stat -f%z "$lock" 2>/dev/null)
  # Only remove if 0 bytes (never written). Non-zero = real in-progress op.
  if [[ "$size" == "0" ]]; then
    rm -f "$lock" 2>/dev/null && echo "stale-lock-cleared"
    return 0
  fi
  return 1
}

# Run a git operation that takes index.lock, with one stale-lock cleanup retry.
# Usage: git_with_lock_retry <repo-dir> <git args...>
# Sets globals GIT_OUT (combined stdout+stderr) and GIT_RC (exit code).
git_with_lock_retry() {
  local dir=$1; shift
  GIT_OUT=$(git -C "$dir" "$@" 2>&1)
  GIT_RC=$?
  if [[ $GIT_RC -ne 0 && "$GIT_OUT" == *"index.lock"*"File exists"* ]]; then
    if clear_stale_index_lock "$dir" >/dev/null; then
      GIT_OUT=$(git -C "$dir" "$@" 2>&1)
      GIT_RC=$?
    fi
  fi
  return $GIT_RC
}

# Process one repo: print one result line inline (so user sees progress) and
# bump the appropriate global counter.
process() {
  local dir=$1
  local name=$2
  local label
  label=$(printf "%-18s" "$name")

  if ! can_sync "$dir"; then
    print_status "$P_YELLOW" "  ⚠ $label  $PRISTINE_REASON"
    (( ATTENTION_N++ ))
    return
  fi

  local fetch_err
  if ! fetch_err=$(git -C "$dir" fetch --quiet --all 2>&1); then
    print_status "$P_RED" "  ✗ $label  fetch: $(first_error_line "$fetch_err")"
    (( FAILED_N++ ))
    return
  fi

  local default
  if ! default=$(default_branch "$dir"); then
    print_status "$P_RED" "  ✗ $label  no default branch"
    (( FAILED_N++ ))
    return
  fi

  local current
  current=$(git -C "$dir" rev-parse --abbrev-ref HEAD 2>/dev/null)
  local from=""
  if [[ "$current" != "$default" ]]; then
    if ! git_with_lock_retry "$dir" checkout --quiet "$default"; then
      print_status "$P_RED" "  ✗ $label  checkout $default: $(first_error_line "$GIT_OUT")"
      (( FAILED_N++ ))
      return
    fi
    from=" (from $current)"
  fi

  local before after
  before=$(git -C "$dir" rev-parse HEAD)
  if ! git_with_lock_retry "$dir" pull --quiet --ff-only; then
    print_status "$P_RED" "  ✗ $label  $default → pull: $(first_error_line "$GIT_OUT")"
    (( FAILED_N++ ))
    return
  fi
  after=$(git -C "$dir" rev-parse HEAD)

  if [[ "$before" == "$after" && -z "$from" ]]; then
    echo "  · $label  $default up to date"
    (( CLEAN_N++ ))
    return
  fi

  local count=0
  [[ "$before" != "$after" ]] && count=$(git -C "$dir" rev-list --count "$before..$after")
  if (( count > 0 )); then
    print_status "$P_GREEN" "  ✓ $label  $default → pulled $count commit(s)$from"
  else
    print_status "$P_GREEN" "  ✓ $label  $default → switched$from"
  fi
  (( UPDATED_N++ ))
}

main() {
  [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && show_help

  local root
  root=$(validate_repository "$EXPECTED_REPO")

  typeset -gi UPDATED_N=0 CLEAN_N=0 ATTENTION_N=0 FAILED_N=0

  print_status "$P_BLUE" "Refreshing work + repos/*..."
  echo

  process "$root" "work"

  if [[ -d "$root/repos" ]]; then
    local dir name
    for dir in "$root/repos"/*/; do
      dir="${dir%/}"
      [[ -d "$dir/.git" ]] || continue
      name="${dir:t}"
      process "$dir" "$name"
    done
  fi

  echo
  print_status "$P_BLUE" "Summary: $UPDATED_N updated · $ATTENTION_N attention · $FAILED_N failed · $CLEAN_N up to date"
}

main "$@"
